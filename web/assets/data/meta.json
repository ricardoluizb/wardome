      {"field": "strength / str", "cost": "50-200 pts (varia c/ STR atual) + 2500 gold", "gain": "+1", "note": "50 se STR<18, 200 se STR>50"},
      {"field": "dexterity / dex", "cost": "50-200 pts (varia c/ DEX atual) + 2500 gold", "gain": "+1", "note": "50 se DEX<18, 200 se DEX>50"},
      {"field": "constitution / con", "cost": "50-200 pts (varia c/ CON atual) + 1000 gold", "gain": "+1", "note": "50 se CON<18, 200 se CON>50"}
